region        = "ap-southeast-1"
environment   = "dev"
key_name      = "your-ec2-keypair"
instance_type = "c6g.metal"       # must be bare-metal for KVM
use_spot      = true
volume_size   = 200

# Pre-built AMI (skip full setup, boots in ~1 min)
# Set to "" to build from scratch (~15 min)
ami_override = ""

# Firecracker + kernel versions
fc_version     = "v1.12.1"
fc_commit      = "a41d3fb"
kernel_version = "vmlinux-6.1.158"
go_version     = "1.25.4"

# Kernel download URL (HTTPS only). If empty, downloads from project GitHub release.
# kernel_url = "https://example.com/kernels/vmlinux-6.1.158-aarch64.bin"

# Your e2b project repo (has ec2-setup.sh, templates, custom configs)
# e2b_repo_url = "https://github.com/your-org/e2b.git"
# e2b_repo_ref = "main"    # branch or tag only (commit SHAs not supported)

# Your infra repo fork (has orchestrator, API, envd source)
# infra_repo_url = "https://github.com/your-org/infra.git"
# infra_repo_ref = "main"
