# =============================================================================
# E2B API Server Environment Variables
# =============================================================================
# Source: infra/packages/api/internal/cfg/model.go (Config struct)
# See also: infra/packages/shared/pkg/env/env.go for NODE_ID
#
# Required variables are marked [REQUIRED]; optional ones have defaults or
# graceful fallbacks when empty.
# =============================================================================

# --- [REQUIRED] Database ---
# PostgreSQL connection string. The API will not start without this.
POSTGRES_CONNECTION_STRING=postgresql://e2b:password@localhost:5432/e2b?sslmode=disable

# Auth database connection string. Defaults to POSTGRES_CONNECTION_STRING if unset.
# AUTH_DB_CONNECTION_STRING=
# AUTH_DB_READ_REPLICA_CONNECTION_STRING=

# Connection pool tuning
# DB_MAX_OPEN_CONNECTIONS=40
# DB_MIN_IDLE_CONNECTIONS=5
# AUTH_DB_MAX_OPEN_CONNECTIONS=20
# AUTH_DB_MIN_IDLE_CONNECTIONS=5

# --- [REQUIRED] Redis ---
# At least one of REDIS_URL or REDIS_CLUSTER_URL must be set.
# If neither is set, the API server will exit with a fatal error.
REDIS_URL=redis://localhost:6379
# REDIS_CLUSTER_URL=
# REDIS_TLS_CA_BASE64=
# REDIS_POOL_SIZE=160

# --- [REQUIRED] Node identity ---
# NODE_ID is read via env.GetNodeID() and panics if missing.
NODE_ID=api-node-1

# --- Networking ---
# Domain name used in sandbox URLs.
# Default: "" (empty string -- set for production).
DOMAIN_NAME=e2b.example.com

# Port for the gRPC server that the client-proxy calls for auto-resume.
# Default: 5009
# API_GRPC_PORT=5009

# --- Sandbox storage backend ---
# Controls how running sandbox state is tracked.
# "memory" -- in-memory (single-node dev); also shadow-writes to Redis.
# "redis"  -- Redis-backed (production, multi-node).
# Default: "memory"
SANDBOX_STORAGE_BACKEND=memory

# --- [REQUIRED] Sandbox access token seed ---
# Used to generate per-sandbox HMAC access tokens.
# Must be a non-empty string. Pick any secure random value.
SANDBOX_ACCESS_TOKEN_HASH_SEED=change-me-to-a-random-secret

# --- Kernel version ---
# Default kernel for new sandboxes. If unset, falls back to
# featureflags.DefaultKernelVersion ("vmlinux-6.1.158").
# DEFAULT_KERNEL_VERSION=vmlinux-6.1.158

# --- Nomad (orchestrator discovery) ---
# NOMAD_ADDRESS=http://localhost:4646
# NOMAD_TOKEN=

# --- Admin ---
# If set, enables the AdminTokenAuth authenticator (X-Admin-Token header).
# ADMIN_TOKEN=

# --- Observability (all optional -- graceful fallbacks when empty) ---
# LOKI_URL=
# LOKI_USER=
# LOKI_PASSWORD=
# CLICKHOUSE_CONNECTION_STRING=
# POSTHOG_API_KEY=
# LOGS_COLLECTOR_ADDRESS=

# --- Analytics collector (optional) ---
# ANALYTICS_COLLECTOR_API_TOKEN=
# ANALYTICS_COLLECTOR_HOST=

# --- Supabase auth (NOT needed for self-hosted API-key-only auth) ---
# When unset, Supabase authenticators are registered but will fail for any
# request that tries to use them, which is fine -- we use API key auth only.
# SUPABASE_JWT_SECRETS=

# --- Volume token signing (optional, for persistent volumes feature) ---
# VOLUME_TOKEN_ISSUER=
# VOLUME_TOKEN_SIGNING_METHOD=
# VOLUME_TOKEN_SIGNING_KEY=
# VOLUME_TOKEN_SIGNING_KEY_NAME=
# VOLUME_TOKEN_DURATION=1h

# --- Persistent volumes ---
# DEFAULT_PERSISTENT_VOLUME_TYPE=
