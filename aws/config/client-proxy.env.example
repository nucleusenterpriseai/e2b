# =============================================================================
# E2B Client-Proxy Environment Variables
# =============================================================================
# Source: infra/packages/client-proxy/internal/cfg/model.go (Config struct)
# See also: infra/packages/shared/pkg/env/env.go for NODE_ID
#
# The client-proxy routes SDK traffic to the correct orchestrator node
# by looking up sandbox-to-node mappings in Redis.
# =============================================================================

# --- [REQUIRED] Node identity ---
# NODE_ID is read via env.GetNodeID() and panics if missing.
NODE_ID=proxy-node-1

# --- Proxy ports ---
# Port for proxying sandbox traffic (HTTP/WebSocket).
# Default: 3002
PROXY_PORT=3002

# Port for the health check endpoint.
# Default: 3003
HEALTH_PORT=3003

# --- Redis ---
# At least one of REDIS_URL or REDIS_CLUSTER_URL should be set for
# production use. If neither is set, the proxy falls back to an in-memory
# sandbox catalog (only works for single-node setups).
REDIS_URL=redis://localhost:6379
# REDIS_CLUSTER_URL=
# REDIS_TLS_CA_BASE64=
# REDIS_POOL_SIZE=40

# --- API gRPC address (for auto-resume) ---
# Address of the API server's gRPC endpoint (port matches API_GRPC_PORT).
# If empty, paused sandbox auto-resume is disabled.
API_GRPC_ADDRESS=localhost:5009
